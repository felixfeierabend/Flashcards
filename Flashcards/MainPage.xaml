<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Flashcards.MainPage"
             Title="Flashcard Deck"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgLight}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <HorizontalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center">
            <Button x:Name="buttonLoadDeck" 
                    Text="Load Dataset" 
                    Clicked="ButtonLoadDeck_Clicked"
                    BackgroundColor="{StaticResource PrimaryColor}" 
                    TextColor="White"/>

            <Button x:Name="buttonToggleTheme" 
                    Text="Toggle Theme" 
                    Clicked="ButtonToggleTheme_Clicked" />
        </HorizontalStackLayout>

        <CollectionView x:Name="collectionViewCards" Grid.Row="1" Margin="0,20,0,0">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12" Padding="15" StrokeThickness="0" StrokeShape="RoundRectangle 12"
                           BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#1E1E1E}">
                        <Grid ColumnDefinitions="*, Auto, Auto"
                              ColumnSpacing="10">
                            <Label Text="{Binding Question}" 
                                   TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                                   VerticalOptions="Center" />
                            <Button x:Name="buttonEditCard" 
                                    Grid.Column="1" 
                                    Padding="12,6"
                                    Text="Edit" 
                                    CommandParameter="{Binding .}"
                                    Clicked="ButtonEditCard_Clicked" />
                            <Button x:Name="buttonDelete"
                                    Grid.Column="2"
                                    Text="Delete"
                                    Padding="12,6"
                                    TextColor="White"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="DarkRed"
                                    Clicked="buttonDelete_Clicked"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,10,0,0">

            <Button x:Name="buttonStartStudy" 
            Text="Start Studying" 
            Clicked="ButtonStartStudy_Clicked"
            BackgroundColor="{StaticResource PrimaryColor}" 
            TextColor="White"
            FontAttributes="Bold"
            HeightRequest="60"
            CornerRadius="10"/>

            <Button x:Name="buttonAddNewCard" 
            Text="Add New Card" 
            Clicked="ButtonAddNewCard_Clicked"
            BackgroundColor="Transparent" 
            BorderColor="{StaticResource PrimaryColor}"
            BorderWidth="1"
            TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

            <Button x:Name="buttonSave" 
            Text="Save" 
            Clicked="ButtonSave_Clicked"
            BackgroundColor="Transparent" 
            BorderColor="{StaticResource PrimaryColor}"
            BorderWidth="1"
            TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

        </VerticalStackLayout>
    </Grid>

</ContentPage>
